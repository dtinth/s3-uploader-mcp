{
  "tasks": {
    "start": "deno run -A main.ts",
    "test": "deno test -A --coverage",
    "check": "deno check **/*.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/testing": "jsr:@std/testing@^1.0.19",
    "@std/uuid": "jsr:@std/uuid@^1.1.1",
    "hono": "npm:hono@^4",
    "jose": "npm:jose@^6",
    "aws4fetch": "npm:aws4fetch@^1"
  },
  "lint": {
    "rules": {
      "include": ["no-unused-vars", "no-undef"]
    }
  },
  "fmt": {
    "lineWidth": 80,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": true
  }
}
